{
  "name": "proofchain-api",
  "version": "0.1.0",
  "private": true,
  "description": "Tamper-evident audit logging API with verifiable integrity proofs.",
  "type": "module",
  "bin": {
    "proofchain": "./bin/proofchain.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "check:env": "tsx scripts/check-env.ts",
    "demo": "tsx scripts/demo.ts",
    "demo:anchors": "tsx scripts/demo-anchors.ts",
    "demo:blocks": "tsx scripts/demo-blocks.ts",
    "demo:cli": "tsx scripts/demo-cli-verifier.ts",
    "demo:events": "tsx scripts/demo-events.ts",
    "demo:export": "tsx scripts/demo-export-proof.ts",
    "demo:ledger": "tsx scripts/demo-ledger.ts",
    "demo:proof": "tsx scripts/demo-proof.ts",
    "demo:server": "tsx scripts/demo-server.ts",
    "dev": "tsx scripts/demo-server.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "mongodb": "^6.14.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  }
}
