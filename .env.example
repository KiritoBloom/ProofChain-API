NODE_ENV=development
APP_NAME=ProofChain API
API_BASE_URL=http://localhost:3000
LOG_LEVEL=info
CRON_SECRET=replace_with_cron_secret
BLOCK_SEAL_TOKEN=replace_with_manual_block_seal_token
EVENT_READ_TOKEN=replace_with_event_read_token
TRANSPARENCY_AUTO_ANCHOR=true
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGODB_DB_NAME=proofchain
SIGNING_PRIVATE_KEY=replace_with_private_key
SIGNING_PUBLIC_KEY=replace_with_public_key
SIGNING_KEY_ID=main-2026-01
